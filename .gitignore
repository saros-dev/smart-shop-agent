.env
.env.*

# IDE
.vscode/
.idea/

# OS Files
.DS_Store
Thumbs.db

# Playwright
playwright-report/
test-results/

# Cache
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Local database
*.db
*.sqlite3

# Temporary files
tmp/
temp/

# Node (اگر بعداً فرانت اضافه کردی)
node_modules/

